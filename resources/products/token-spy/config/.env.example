# Token Spy — Environment Configuration
# ============================================
#
# SETUP:
#   cp .env.example .env
#   Edit the REQUIRED values below, then: make start
#
# ============================================

# ============================================
# REQUIRED — Set These Before Starting
# ============================================

# PostgreSQL password — REQUIRED
# Generate one: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME

# Provider key encryption secret — REQUIRED
# Used to encrypt upstream API keys (Anthropic, OpenAI, etc.) at rest.
# Must be the same for proxy and dashboard containers.
# Generate one: openssl rand -base64 32
PROVIDER_KEY_SECRET=CHANGE_ME

# ============================================
# Proxy Configuration
# ============================================

# Port mappings (change if you have conflicts)
TOKEN_SPY_PROXY_PORT=8080
TOKEN_SPY_DASHBOARD_PORT=3001
TOKEN_SPY_DB_PORT=5432

# Default upstream LLM API — used only if no provider key is configured
# in the dashboard. Once you add a provider key via the UI, that takes
# precedence. You can usually leave this as-is.
DEFAULT_UPSTREAM_URL=https://api.openai.com/v1
DEFAULT_API_KEY=

# ============================================
# Dashboard Authentication (Optional)
# ============================================

# Enable basic auth for the dashboard (recommended for public deployments)
DASHBOARD_AUTH_ENABLED=false
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=

# ============================================
# Logging & Performance
# ============================================

LOG_LEVEL=INFO
ENABLE_REQUEST_LOGGING=true
ENABLE_SSE=true

# High-volume collector (enable with: docker compose --profile high-volume up -d)
COLLECTOR_BATCH_SIZE=100
COLLECTOR_FLUSH_INTERVAL=5
